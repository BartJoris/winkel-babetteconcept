# Odoo Configuration
ODOO_URL=https://www.babetteconcept.be/jsonrpc
ODOO_DB=babetteconcept
#ODOO_USERNAME=your_odoo_username
#ODOO_API_KEY=your_odoo_api_key

# Session Configuration
# Generate a secure random string (at least 32 characters) for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=complex_password_at_least_32_characters_long_change_this_in_production

# Zebra ZPL bridge (optioneel)
# Lokaal: weglaten of http://127.0.0.1:9333/print
# Vercel + Cloudflare Tunnel: https://zebra.babetteconcept.be/print
# ZPL_BRIDGE_URL=https://zebra.babetteconcept.be/print
# Geheim voor bridge; zet dezelfde waarde in de bridge (ZPL_BRIDGE_SECRET) en hier
# ZPL_BRIDGE_SECRET=your_shared_secret_here
# Test Bridge
